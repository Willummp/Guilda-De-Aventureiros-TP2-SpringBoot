# Guilda Aventureiros - Configurações de Ambiente (AWS/Produção)
# Copie os comandos abaixo para o terminal ANTES de rodar o projeto na aula.

# Linux/macOS ou PowerShell (Windows):
# $env:DB_URL="jdbc:postgresql://IP_AWS_DO_PROFESSOR:5432/postgres"
# $env:DB_USER="usuario_da_banca"
# $env:DB_PASSWORD="senha_secreta"

# Ou passe direto pelo comando Maven:
# mvn spring-boot:run -Dspring-boot.run.arguments="--DB_URL=... --DB_USER=... --DB_PASSWORD=..."

DB_URL=jdbc:postgresql://IP_AWS_DO_PROFESSOR:5432/postgres
DB_USER=usuario_da_banca
DB_PASSWORD=senha_secreta
